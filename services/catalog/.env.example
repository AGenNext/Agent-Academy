PORT=4001
HOST=0.0.0.0
AUDIT_SINK=console

# Leave these unset to run with local in-memory seed data.
# Set all of them to enable SurrealDB persistence.
SURREALDB_ENDPOINT=http://localhost:8000
SURREALDB_NAMESPACE=agennext
SURREALDB_DATABASE=academy
SURREALDB_USERNAME=<user>
SURREALDB_PASSWORD=<password>
